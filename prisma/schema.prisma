generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["soldat"]
}

model Ausruestung {
  id           Int    @id @default(autoincrement())
  waffe        waffe
  seriennummer String
  soldatId    Int     @unique @map("soldat_id")
  soldat       soldat @relation(fields: [soldatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([seriennummer])
  @@index([soldatId])
  @@map("ausruestung")
  @@schema("soldat")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model soldat {
  id           Int           @id @default(autoincrement())
  version      Int           @default(0)
  vorname      String
  nachname     String
  geburtsdatum DateTime?     @db.Date
  geschlecht   geschlecht?
  rang         rang?
  username     String
  erzeugt      DateTime      @default(now()) @db.Timestamp(6)
  aktualisiert DateTime      @default(now()) @db.Timestamp(6) @updatedAt
  ausruestung  Ausruestung
  verletzungen   verletzung[]

  @@index([nachname])
  @@map("soldat")
  @@schema("soldat")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model verletzung {
  id                     Int         @id @default(autoincrement())
  verletzungsbezeichnung String
  behandelt              Boolean
  schweregrad            schweregrad
  verletzungsdatum       DateTime    @db.Date
  soldatId              Int         @map("soldat_id")
  soldat                 soldat      @relation(fields: [soldatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([soldatId])
  @@map("verletzung")
  @@schema("soldat")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model verletzungen {
  id                     Int      @id @default(autoincrement())
  verletzungsbezeichnung String
  behandelt              Boolean
  verletzungsdatum       DateTime @db.Date
  soldat_id              Int

  @@index([soldat_id])
  @@schema("soldat")
}

enum geschlecht {
  MAENNLICH
  WEIBLICH

  @@schema("soldat")
}

enum rang {
  REKRUT
  SOLDAT
  ELITE_SOLDAT @map("ELITE-SOLDAT")
  CAPTAIN
  KOMMANDANT

  @@schema("soldat")
}

enum schweregrad {
  LEICHT
  MITTEL
  SCHWER
  KRITISCH

  @@schema("soldat")
}

enum waffe {
  ODM_GEAR
  Schrotflinte
  Klinge

  @@schema("soldat")
}
